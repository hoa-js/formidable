{
  "name": "@hoajs/formidable",
  "version": "0.1.0",
  "description": "Formidable middleware for Hoa.",
  "main": "./dist/cjs/index.cjs",
  "type": "module",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "build": "tsdown",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run type-check && npm run lint && npm run test && npm run build",
    "prepare": "husky"
  },
  "author": "RosApr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoa-js/formidable.git"
  },
  "keywords": [
    "hoa",
    "middleware",
    "formidable",
    "multipart",
    "form",
    "file",
    "body",
    "parser"
  ],
  "dependencies": {
    "formidable": "^3.5.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@hoajs/adapter": "^0.1.3",
    "@hoajs/router": "^0.3.1",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "eslint": "^9.39.4",
    "hoa": "^0.3.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "neostandard": "^0.12.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "hoa": "*"
  },
  "engines": {
    "node": ">=20"
  }
}
